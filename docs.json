{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Fueling Optimizer",
  "colors": {
    "primary": "#10b981",
    "light": "#14b8a6",
    "dark": "#059669",
    "background": {
      "light": "#f8faf9",
      "dark": "#0f1a14"
    }
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Product docs",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Calculator design",
            "pages": [
              "essentials/settings",
              "essentials/navigation"
            ]
          },
          {
            "group": "Docs authoring",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "Team tooling",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoint patterns",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Quickstart",
          "href": "/quickstart",
          "icon": "gauge-high"
        },
        {
          "anchor": "API reference",
          "href": "/api-reference/introduction",
          "icon": "wave-pulse"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "/"
  },
  "navbar": {
    "links": [
      {
        "label": "Quickstart",
        "href": "/quickstart"
      },
      {
        "label": "API reference",
        "href": "/api-reference/introduction"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open docs",
      "href": "/quickstart"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "cursor",
      "vscode"
    ]
  }
}
